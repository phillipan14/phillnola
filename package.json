{
  "name": "phillnola",
  "version": "1.0.0",
  "description": "Open-source AI meeting notepad. No bot. No server. Your keys. Your data.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -n vite,electron \"vite --config vite.config.ts\" \"wait-on http://localhost:5173 && electron .\"",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --outdir=electron --external:electron --external:better-sqlite3 --format=cjs",
    "build": "npm run build:electron && vite build --config vite.config.ts",
    "start": "npm run build:electron && electron .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "electron",
    "meeting-notes",
    "whisper",
    "ai",
    "transcription"
  ],
  "author": "Phillip An",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@tiptap/extension-heading": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/extension-task-item": "^3.20.0",
    "@tiptap/extension-task-list": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@vitejs/plugin-react": "^5.1.4",
    "better-sqlite3": "^12.6.2",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  }
}
